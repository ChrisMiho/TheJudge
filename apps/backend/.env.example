PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
DEBUG_LOGGING=true
LOG_PAYLOADS=true
# Provider mode: "mock" (default) or "bedrock"
ASK_AI_PROVIDER=mock
# Required when ASK_AI_PROVIDER=bedrock
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-v2
# Optional Bedrock runtime controls when ASK_AI_PROVIDER=bedrock
# BEDROCK_TIMEOUT_MS=15000
# BEDROCK_MAX_ATTEMPTS=2
# Optional profile override for local profile/SSO auth flow
# AWS_PROFILE=default
# Fallback env credentials (temporary/session only; never commit real values)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
